FROM python:3.11-slim

# 1. Защита от зависания логов и создания лишних .pyc файлов
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

# 2. Оптимизация кэша pip (ускоряет повторную сборку при изменении кода)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# 3. Оставляем порт по умолчанию, но убираем жесткий reload для гибкости
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001"]
